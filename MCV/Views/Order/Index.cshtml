@model IEnumerable<Entities.Models.Order>
@{
    ViewData["Title"] = "My Orders";
}

<h2 class="fw-bold mb-4">My Orders</h2>

@if (!Model.Any())
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <p class="fw-semibold mb-1">No orders yet</p>
            <p class="text-muted small">Orders will appear here once you place them.</p>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary btn-sm">Browse Products</a>
        </div>
    </div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center py-3">
                <div class="text-muted small">Total</div>
                <div class="fw-bold fs-4">@Model.Count()</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center py-3">
                <div class="text-muted small">Pending</div>
                <div class="fw-bold fs-4">@Model.Count(o => o.Status == Entities.Models.OrderStatus.Pending)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center py-3">
                <div class="text-muted small">Delivered</div>
                <div class="fw-bold fs-4">@Model.Count(o => o.Status == Entities.Models.OrderStatus.Delivered)</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center py-3">
                <div class="text-muted small">Cancelled</div>
                <div class="fw-bold fs-4">@Model.Count(o => o.Status == Entities.Models.OrderStatus.Cancelled)</div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Order #</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Total</th>
                            <th>Ship To</th>
                            <th class="text-end pe-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var badgeClass = item.Status switch
                            {
                                Entities.Models.OrderStatus.Pending => "bg-warning text-dark",
                                Entities.Models.OrderStatus.Processing => "bg-primary",
                                Entities.Models.OrderStatus.Shipped => "bg-info",
                                Entities.Models.OrderStatus.Delivered => "bg-success",
                                Entities.Models.OrderStatus.Cancelled => "bg-danger",
                                _ => "bg-secondary"
                            };

                            <tr>
                                <td class="ps-3 fw-semibold text-primary">#@item.OrderNumber</td>
                                <td><span class="badge rounded-pill @badgeClass">@item.Status</span></td>
                                <td class="text-muted small">@item.OrderDate.ToString("MMM dd, yyyy")</td>
                                <td class="fw-semibold text-success">@item.TotalAmount.ToString("C")</td>
                                <td class="text-muted small">@item.ShippingAddress?.City</td>
                                <td class="text-end pe-3">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@using Entities.Models
@model User
@{
    ViewData["Title"] = "Update Roles";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="card-title mb-1">Update Roles</h3>
                <p class="text-muted mb-4">User: <strong>@Model.FullName</strong> (@Model.Email)</p>

                <form asp-action="UpdateRoles" asp-route-id="@Model.Id" method="post">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label for="userRoles" class="form-label fw-semibold">Current Roles</label>
                            <p class="text-muted small mb-2">Select roles to remove</p>
                            <select id="userRoles" name="RolesToRemove" class="form-select" multiple size="4">
                                @foreach (var role in ViewBag.UserRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="allRoles" class="form-label fw-semibold">Available Roles</label>
                            <p class="text-muted small mb-2">Select roles to add</p>
                            <select id="allRoles" name="RolesToAdd" class="form-select" multiple size="4">
                                @foreach (var role in ViewBag.NonUserRoles)
                                {
                                    <option value="@role">@role</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

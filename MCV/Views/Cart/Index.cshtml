@model MCV.ViewModels.Cart.CartVM
@{
    ViewData["Title"] = "Shopping Cart";
}

<h2 class="fw-bold mb-1">Shopping Cart</h2>
<p class="text-muted mb-4">@Model.ItemCount item(s) in your cart</p>

@if (Model.Items.Count == 0)
{
    <div class="card shadow-sm">
        <div class="card-body text-center py-5">
            <h5 class="text-muted mb-3">Your cart is empty</h5>
            <a asp-controller="Catalog" asp-action="Index" class="btn btn-primary">Browse Products</a>
        </div>
    </div>
}
else
{
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-3">Product</th>
                                <th style="width:160px">Quantity</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-end">Subtotal</th>
                                <th style="width:50px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="ps-3">
                                        <strong>@item.ProductName</strong>
                                        <br /><small class="text-muted">SKU: @item.SKU</small>
                                    </td>
                                    <td>
                                        <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center gap-1">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <input type="number" name="quantity" value="@item.Quantity"
                                                   min="1" max="@item.StockQuantity"
                                                   class="form-control form-control-sm" style="width:70px" />
                                            <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                                        </form>
                                    </td>
                                    <td class="text-end">@item.UnitPrice.ToString("C")</td>
                                    <td class="text-end fw-bold">@item.LineTotal.ToString("C")</td>
                                    <td>
                                        <form asp-action="Remove" method="post">
                                            <input type="hidden" name="cartItemId" value="@item.CartItemId" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="d-flex justify-content-between mt-3">
                <a asp-controller="Catalog" asp-action="Index" class="btn btn-outline-primary">Continue Shopping</a>
                <form asp-action="Clear" method="post">
                    <button type="submit" class="btn btn-outline-danger">Clear Cart</button>
                </form>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title mb-3">Order Summary</h5>
                    <hr />
                    <div class="d-flex justify-content-between mb-2">
                        <span>Items (@Model.ItemCount)</span>
                        <span>@Model.Total.ToString("C")</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between fw-bold fs-5 mb-3">
                        <span>Total</span>
                        <span>@Model.Total.ToString("C")</span>
                    </div>
                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary w-100">
                        Proceed to Checkout
                    </a>
                </div>
            </div>
        </div>
    </div>
}

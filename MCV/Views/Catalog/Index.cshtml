@model MCV.ViewModels.Catalog.CatalogVM
@{
    ViewData["Title"] = "Catalog";
}

<div class="container mt-4">
    <h1 class="mb-4">Product Catalog</h1>

    @* ── Filter Bar ── *@
    <form method="get" asp-action="Index" class="row g-3 mb-4 align-items-end">
        <div class="col-md-3">
            <label class="form-label">Category</label>
            <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select">
                <option value="">All Categories</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Search</label>
            <input asp-for="Q" class="form-control" placeholder="Search by name or SKU..." />
        </div>
        <div class="col-md-3">
            <label class="form-label">Sort by</label>
            <select asp-for="Sort" class="form-select">
                <option value="name">Name (A–Z)</option>
                <option value="price_asc">Price: Low → High</option>
                <option value="price_desc">Price: High → Low</option>
                <option value="newest">Newest First</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>
    </form>

    @* ── Results Info ── *@
    @if (Model.TotalItems > 0)
    {
        <p class="text-muted">
            Showing @(((Model.Page - 1) * Model.PageSize) + 1)–@Math.Min(Model.Page * Model.PageSize, Model.TotalItems)
            of @Model.TotalItems products
        </p>
    }

    @* ── Product Grid ── *@
    @if (Model.Products.Count == 0)
    {
        <div class="alert alert-info">No products found matching your criteria.</div>
    }
    else
    {

        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var product in Model.Products)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="text-muted small mb-1">SKU: @product.SKU</p>
                            <span class="badge bg-secondary mb-2" style="width:fit-content">
                                @(product.Category?.Name ?? "Uncategorized")
                            </span>
                            <p class="fs-5 fw-bold mt-auto mb-1">@product.Price.ToString("C")</p>
                            <p class="small @(product.StockQuantity > 0 ? "text-success" : "text-danger")">
                                @(product.StockQuantity > 0 ? $"In Stock ({product.StockQuantity})" : "Out of Stock")
                            </p>

                            <!-- Buttons container -->
                            <div class="d-flex gap-2 mt-2">
                                <a asp-action="Details"
                                   asp-route-id="@product.Id"
                                   class="btn btn-info btn-sm flex-fill">
                                    Details
                                </a>

                                <form asp-controller="Cart"
                                      asp-action="Add"
                                      method="post"
                                      asp-route-productId="@product.Id"
                                      class="d-flex">
                                    <button type="submit" class="btn btn-warning btn-sm flex-fill">
                                        Add to Cart
                                    </button>

                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    @* ── Pagination ── *@
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4" aria-label="Catalog pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-q="@Model.Q"
                       asp-route-sort="@Model.Sort"
                       asp-route-page="@(Model.Page - 1)">
                        &laquo; Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-q="@Model.Q"
                           asp-route-sort="@Model.Sort"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-categoryId="@Model.CategoryId"
                       asp-route-q="@Model.Q"
                       asp-route-sort="@Model.Sort"
                       asp-route-page="@(Model.Page + 1)">
                        Next &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>

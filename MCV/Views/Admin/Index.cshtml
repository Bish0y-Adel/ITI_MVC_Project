@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="fw-bold mb-4">Admin Dashboard</h2>

<div class="row g-4">
    <div class="col-md-3">
        <div class="card shadow-sm text-center py-4">
            <div class="card-body">
                <h5 class="card-title">Users</h5>
                <p class="text-muted small">Manage user accounts and roles</p>
                <a asp-controller="Manager" asp-action="Index" class="btn btn-outline-primary btn-sm">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center py-4">
            <div class="card-body">
                <h5 class="card-title">Categories</h5>
                <p class="text-muted small">Organize product categories</p>
                <a asp-controller="ManageCategory" asp-action="Index" class="btn btn-outline-primary btn-sm">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center py-4">
            <div class="card-body">
                <h5 class="card-title">Products</h5>
                <p class="text-muted small">Add, edit, and manage products</p>
                <a asp-controller="ManageProducts" asp-action="Index" class="btn btn-outline-primary btn-sm">Manage</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm text-center py-4">
            <div class="card-body">
                <h5 class="card-title">Orders</h5>
                <p class="text-muted small">Track and update orders</p>
                <a asp-controller="ManageOrders" asp-action="Index" class="btn btn-outline-primary btn-sm">Manage</a>
            </div>
        </div>
    </div>
</div>

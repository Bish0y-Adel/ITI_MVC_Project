@using Entities.Models
@using MCV.ViewModels.ManageOrders
@model IEnumerable<OrdersVM>
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Manage Orders</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Order #</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Total</th>
                        <th>Customer</th>
                        <th>Shipping Address</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var badgeClass = item.StatusNumber switch
                        {
                            OrderStatus.Pending => "bg-warning text-dark",
                            OrderStatus.Processing => "bg-primary",
                            OrderStatus.Shipped => "bg-info",
                            OrderStatus.Delivered => "bg-success",
                            OrderStatus.Cancelled => "bg-danger",
                            _ => "bg-secondary"
                        };

                        <tr>
                            <td class="ps-3 fw-semibold text-primary">#@item.OrderNumber</td>
                            <td>
                                <form asp-action="UpdateStatus" method="post" class="d-flex align-items-center gap-2">
                                    <input type="hidden" name="OrderId" value="@item.OrderId" />
                                    <select name="StatusNumber"
                                            asp-for="@item.StatusNumber"
                                            asp-items="item.OrderStatus"
                                            class="form-select form-select-sm" style="width:140px">
                                    </select>
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">Update</button>
                                </form>
                            </td>
                            <td class="text-muted small">@item.OrderDate.ToString("MMM dd, yyyy")</td>
                            <td class="fw-semibold text-success">@item.TotalAmount.ToString("C")</td>
                            <td class="small">@item.UserName</td>
                            <td class="text-muted small">@item.ShippingAddress</td>
                            <td class="text-end pe-3">
                                <a asp-action="Details" asp-route-id="@item.OrderId" class="btn btn-sm btn-outline-secondary">Details</a>
                                <a asp-action="Delete" asp-route-id="@item.OrderId"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Delete this order?')">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

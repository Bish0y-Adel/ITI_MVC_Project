@model Entities.Models.Order

@{
    ViewData["Title"] = $"Order #{Model.OrderNumber}";

    var badgeClass = Model.Status switch
    {
        Entities.Models.OrderStatus.Pending => "bg-warning text-dark",
        Entities.Models.OrderStatus.Processing => "bg-primary",
        Entities.Models.OrderStatus.Shipped => "bg-info",
        Entities.Models.OrderStatus.Delivered => "bg-success",
        Entities.Models.OrderStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">Order #@Model.OrderNumber</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Back to Orders</a>
</div>

<div class="row g-4">
    <!-- Left column: Order info + Items -->
    <div class="col-lg-8">
        <!-- Order Summary Card -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">Order Information</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-sm-4">
                        <div class="text-muted small">Status</div>
                        <span class="badge @badgeClass fs-6">@Model.Status</span>
                    </div>
                    <div class="col-sm-4">
                        <div class="text-muted small">Order Date</div>
                        <div class="fw-semibold">@Model.OrderDate.ToString("MMM dd, yyyy h:mm tt")</div>
                    </div>
                    <div class="col-sm-4">
                        <div class="text-muted small">Total Amount</div>
                        <div class="fw-bold fs-5 text-success">@Model.TotalAmount.ToString("C")</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Items Card -->
        <div class="card shadow-sm">
            <div class="card-header bg-transparent">
                <h5 class="mb-0">Items (@Model.OrderItems.Count)</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Product</th>
                            <th>SKU</th>
                            <th class="text-center">Qty</th>
                            <th class="text-end">Unit Price</th>
                            <th class="text-end pe-3">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold">@item.Product.Name</td>
                                <td class="text-muted small">@item.Product.SKU</td>
                                <td class="text-center">@item.Quantity</td>
                                <td class="text-end">@item.UnitPrice.ToString("C")</td>
                                <td class="text-end pe-3 fw-semibold">@item.LineTotal.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="4" class="text-end fw-bold">Total</td>
                            <td class="text-end pe-3 fw-bold fs-5">@Model.TotalAmount.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <!-- Right column: Customer + Address -->
    <div class="col-lg-4">
        <!-- Customer Card -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Customer</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.User.FullName</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8 text-break">@Model.User.Email</dd>
                </dl>
            </div>
        </div>

        <!-- Shipping Address Card -->
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h5 class="card-title mb-3">Shipping Address</h5>
                <p class="mb-1">@Model.ShippingAddress.Street</p>
                <p class="mb-1">@Model.ShippingAddress.City</p>
                <p class="mb-1">@Model.ShippingAddress.Country</p>
                @if (!string.IsNullOrEmpty(Model.ShippingAddress.Zip))
                {
                    <p class="mb-0 text-muted">@Model.ShippingAddress.Zip</p>
                }
            </div>
        </div>

        <!-- Audit Card -->
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title mb-3">Timestamps</h5>
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted small">Created</dt>
                    <dd class="col-sm-7 small">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>
                    <dt class="col-sm-5 text-muted small">Updated</dt>
                    <dd class="col-sm-7 small">@(Model.UpdatedAt?.ToString("MMM dd, yyyy") ?? "—")</dd>
                </dl>
            </div>
        </div>
    </div>
</div>
